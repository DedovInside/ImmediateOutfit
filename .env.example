# Скопируй файл в .env и подставь свои значения
# cp .env.example .env

# Токен бота от @BotFather, формат: 12345:AA...
BOT_TOKEN=ВАШ_ТОКЕН_БОТА

# Ключ OpenWeatherMap для автоопределения погоды на шаге анкеты.
# Если пустой — кнопка «📍 По моему городу» останется, но клик ответит,
# что интеграция не подключена. Регистрация бесплатна: https://openweathermap.org/api
OWM_API_KEY=
