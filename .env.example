# Скопируй файл в .env и подставь свои значения
# cp .env.example .env

# Токен бота от @BotFather, формат: 12345:AA...
BOT_TOKEN=ВАШ_ТОКЕН_БОТА

# Ключ OpenWeatherMap для автоопределения погоды на шаге анкеты.
# Если пустой — можно выбирать погоду вручную.
OWM_API_KEY=

# Если пустой — используется data/immediateoutfit.db.
DB_PATH=

# Optional DeepSeek text-AI layer.
# Если false или ключ пустой — бот использует rule-based fallback.
AI_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=15
AI_FREE_LIMIT=5

# Demo seed для защиты. Если true, при запуске bot.py в SQLite добавятся
# презентационные пользователи/события из Excel. Реальных пользователей не удаляет.
DEMO_SEED_ON_START=false
DEMO_XLSX_PATH=C:\Users\johnn\Downloads\Telegram Desktop\ImmediateOutfit_AARRR_dataset.xlsx
